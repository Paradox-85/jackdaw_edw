{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  
  "env": {
    "ANTHROPIC_MODEL": "claude-sonnet-4-6"
  },
  
  "permissions": {
    "allow": [
      "mcp__perplexity",
      "mcp__proxmox",
      "Bash(etl/**)",
      "Bash(pytest)",
      "Bash(black)",
      "Bash(ruff)",
      "Bash(pre-commit)",
      "Read(etl/**)",
      "Read(sql/**)",
      "Read(config/**)",
      "Read(CLAUDE*.md)",
      "Read(.claude/**)"
    ],
    "deny": [
      "Read(*.env*)",
      "Read(secrets/**)",
      "Read(*.pem)",
      "Read(ssh/**)",
      "Read(data/private/**)",
      "Read(logs/prod/**)"
    ],
    "ask": [
      "Bash(rm)",
      "Bash(docker rm)",
      "Bash(docker compose down)",
      "Write(etl/**)"
    ],
    "defaultMode": "default"
  },
  
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "ruff check --fix",
            "timeout": 10,
            "statusMessage": "Linting with ruff..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "scripts/pre-hook.sh",
            "statusMessage": "Initializing EDW environment..."
          }
        ]
      }
    ]
  },
  
  "enableAllProjectMcpServers": true,
  "includeGitInstructions": true,
  "respectGitignore": true
}