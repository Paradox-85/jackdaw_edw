# docker/.env.example (commit to Git)
# Copy to docker/.env (NOT committed)

# PostgreSQL
POSTGRES_USER=edw_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=edw
POSTGRES_PORT=5432

# Neo4j
NEO4J_AUTH=neo4j/your_neo4j_password
NEO4J_PORT=7687

# Qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=your_qdrant_key

# Ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=mistral

# Prefect (optional)
PREFECT_API_URL=http://localhost:4200/api