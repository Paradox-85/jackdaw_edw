# docker/infra_configs/.env.example
# Copy to docker/infra_configs/.env and fill in real values.
# .env is in .gitignore and is NEVER committed to git.
#
# Used by: jackdaw-edw_docker-compose.yml
# All ${VAR} references in that file resolve from this file.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres_admin
POSTGRES_PASSWORD=
POSTGRES_DB=engineering_core
PGDATA=/var/lib/postgresql/data/pgdata
PREFECT_DB=prefect

# ── EDW viewer role (read-only, used by jackdaw-ui) ──────────────────────────
EDW_VIEWER_PASSWORD=

# ── DbGate admin UI ───────────────────────────────────────────────────────────
DBGATE_ADMIN_USER=admin
DBGATE_ADMIN_PASSWORD=

# ── LLM API key — shared with ai-core llamacpp service ───────────────────────
# Same key as LLAMA_API_KEY in ai-core_docker-compose.yml/.env
# Used by prefect-worker → load_config() → LLAMA_API_KEY overlay
LLAMA_API_KEY=
